{
  "name": "@acroyoga/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./types/*": "./src/types/*.ts",
    "./api": "./src/api/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./schemas/*": "./src/schemas/*.ts",
    "./utils": "./src/utils/index.ts",
    "./utils/*": "./src/utils/*.ts",
    "./*": "./src/*.ts"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  }
}

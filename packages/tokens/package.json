{
  "name": "@acroyoga/tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "tokens:build": "node --import tsx build.ts",
    "tokens:watch": "node --import tsx --watch build.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "style-dictionary": "^4.4.0"
  }
}
